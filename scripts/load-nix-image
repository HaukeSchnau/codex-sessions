#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

image_ref="codex-sessions-archive-server:nix"
result_link="${ARCHIVE_IMAGE_RESULT:-$repo_root/result-archive-server-image}"

build_target=".#archive-server-image"
if [[ -n "${ARCHIVE_IMAGE_SYSTEM:-}" ]]; then
  build_target=".#packages.${ARCHIVE_IMAGE_SYSTEM}.archive-server-image"
else
  current_system="$(nix eval --raw --impure --expr builtins.currentSystem)"
  if [[ "$current_system" == *-darwin ]]; then
    docker_arch="$(docker version --format '{{.Server.Arch}}')"
    case "$docker_arch" in
      arm64 | aarch64) build_target=".#packages.aarch64-linux.archive-server-image" ;;
      amd64 | x86_64) build_target=".#packages.x86_64-linux.archive-server-image" ;;
      *)
        echo "Unsupported Docker architecture: $docker_arch" >&2
        exit 1
        ;;
    esac
  fi
fi

nix build --max-jobs "${ARCHIVE_IMAGE_MAX_JOBS:-1}" "$build_target" --out-link "$result_link"
docker load --input "$result_link"

echo "Loaded $image_ref"
