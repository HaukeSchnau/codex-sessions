#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

image_ref="codex-sessions-archive-server:nix"
result_link="${ARCHIVE_IMAGE_RESULT:-$repo_root/result-archive-server-image}"

default_image_system() {
  local current_system
  current_system="$(nix eval --raw --impure --expr builtins.currentSystem)"
  case "$current_system" in
    aarch64-linux | x86_64-linux) printf '%s\n' "$current_system" ;;
    *-darwin) printf '%s\n' "aarch64-linux" ;;
    *)
      echo "Unsupported host system for Docker image build: $current_system" >&2
      exit 1
      ;;
  esac
}

image_system="${ARCHIVE_IMAGE_SYSTEM:-$(default_image_system)}"
case "$image_system" in
  aarch64-linux | x86_64-linux) ;;
  *)
    echo "Unsupported ARCHIVE_IMAGE_SYSTEM: $image_system" >&2
    echo "Expected aarch64-linux or x86_64-linux." >&2
    exit 1
    ;;
esac

build_target=".#packages.${image_system}.archive-server-image"
build_args=()
if [[ -n "${ARCHIVE_IMAGE_MAX_JOBS:-}" ]]; then
  build_args+=(--max-jobs "$ARCHIVE_IMAGE_MAX_JOBS")
fi

echo "Building $build_target with Nix"
nix build "${build_args[@]}" "$build_target" --out-link "$result_link"
docker load --input "$result_link"

echo "Loaded $image_ref"
